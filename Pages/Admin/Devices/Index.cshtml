@page
@model BelovskayaMonitoring.Pages.Admin.Devices.IndexModel
@{
    ViewData["Title"] = "Управление устройствами";
}

<div class="shield-panel">
    <div class="panel-title">Управление устройствами</div>
    <a asp-page="./Create" class="btn btn-success mb-3">Добавить устройство</a>

    <table class="table table-dark-striped">
        <thead>
            <tr>
                <th>Название</th>
                <th>IP</th>
                <th>Статус</th>
                <th>Последняя проверка</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var device in Model.Devices)
            {
                <tr>
                    <td>@device.Name</td>
                    <td>@device.IPAddress</td>
                    <td>@device.Status</td>
                    <td>@device.LastChecked?.ToString("HH:mm:ss")</td>
                    <td>
                        <a asp-page="./Edit" asp-route-id="@device.Id" class="btn btn-sm btn-primary">Ред.</a>
                        <form method="post" asp-page-handler="ChangeStatus" asp-route-id="@device.Id" style="display:inline;">
                            <button type="submit" class="btn btn-sm btn-warning">
                                @(device.Status == BelovskayaMonitoring.Models.DeviceStatus.Online ? "Уронить" : "Восстановить")
                            </button>
                        </form>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@device.Id" style="display:inline;" onsubmit="return confirm('Удалить устройство?');">
                            <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>