@page "{id:int}"
@model BelovskayaMonitoring.Pages.Admin.Devices.EditModel
@{
    ViewData["Title"] = "Редактировать устройство";
}

<div class="container mt-4">
    <h2>Редактирование @Model.Device.Name</h2>
    <hr />
    <form method="post">
        <input type="hidden" name="Id" value="@Model.Device.Id" />
        <div class="mb-3">
            <label class="form-label">Название</label>
            <input name="Name" class="form-control" value="@Model.Device.Name" required />
        </div>
        <div class="mb-3">
            <label class="form-label">IP-адрес</label>
            <input name="IPAddress" class="form-control" value="@Model.Device.IPAddress" />
        </div>
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a asp-page="./Index" class="btn btn-secondary">Отмена</a>
    </form>
</div>