@page
@model BelovskayaMonitoring.Pages.Admin.Devices.CreateModel
@{
    ViewData["Title"] = "Добавить устройство";
}

<div class="container mt-4">
    <h2>Добавить устройство</h2>
    <hr />
    <form method="post">
        <div class="mb-3">
            <label class="form-label">Название</label>
            <input name="Name" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">IP-адрес</label>
            <input name="IPAddress" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Создать</button>
        <a asp-page="./Index" class="btn btn-secondary">Отмена</a>
    </form>
</div>