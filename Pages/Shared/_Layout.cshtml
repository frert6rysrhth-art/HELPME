@using Microsoft.AspNetCore.Identity
@using BelovskayaMonitoring.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – ССМ</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Боковая панель -->
    <aside class="sidebar">
        <div class="sidebar-header text-center">
            <div class="brand-logo">
                <svg width="170" height="60" viewBox="0 0 170 60" xmlns="http://www.w3.org/2000/svg">
                    <!-- Внешняя рамка -->
                    <rect x="2" y="2" width="166" height="56" rx="8"
                          fill="none" stroke="var(--accent-blue)" stroke-width="1" />
                    <!-- Внутренняя рамка -->
                    <rect x="6" y="6" width="158" height="48" rx="6"
                          fill="none" stroke="var(--accent-blue)" stroke-width="2" opacity="0.7" />

                    <!-- Градиент для букв -->
                    <defs>
                        <linearGradient id="textGrad" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="#93c5fd" />
                            <stop offset="100%" stop-color="#2563eb" />
                        </linearGradient>
                    </defs>

                    <!-- Левые индикаторы (зеркальные, волна сходится к центру) -->
                    <rect x="18" y="28" width="4" height="6" rx="2"
                          fill="var(--accent-green)" class="indicator-bar" style="animation-delay: 0s" />
                    <rect x="26" y="24" width="4" height="12" rx="2"
                          fill="var(--accent-green)" class="indicator-bar" style="animation-delay: 0.3s" />
                    <rect x="34" y="20" width="4" height="20" rx="2"
                          fill="var(--accent-green)" class="indicator-bar" style="animation-delay: 0.6s" />

                    <!-- Текст ССМ (строго по центру) -->
                    <text x="88" y="40" font-family="'Roboto Mono', 'Courier New', monospace"
                          font-size="32" font-weight="bold" fill="url(#textGrad)"
                          letter-spacing="6" text-anchor="middle">ССМ</text>

                    <!-- Правые индикаторы (зеркальные, волна сходится к центру) -->
                    <rect x="136" y="20" width="4" height="20" rx="2"
                          fill="var(--accent-green)" class="indicator-bar" style="animation-delay: 0.6s" />
                    <rect x="144" y="24" width="4" height="12" rx="2"
                          fill="var(--accent-green)" class="indicator-bar" style="animation-delay: 0.3s" />
                    <rect x="152" y="28" width="4" height="6" rx="2"
                          fill="var(--accent-green)" class="indicator-bar" style="animation-delay: 0s" />
                </svg>
            </div>
            <div class="brand-subtitle">система сетевого мониторинга</div>
        </div>

        </div>
        <ul class="sidebar-nav">
            <li class="nav-item">
                <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Index") ? "active" : "")" asp-page="/Index">Главная</a>
            </li>
            @if (SignInManager.IsSignedIn(User))
            {
                <li class="nav-item">
                    <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Chats") ? "active" : "")" asp-page="/Chats/Index">Чаты</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Devices") ? "active" : "")" asp-page="/Devices/Index">Мониторинг</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Analytics") ? "active" : "")" asp-page="/Analytics">Аналитика</a>
                </li>
            }
            @if (User.IsInRole("Administrator"))
            {
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Администрирование
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" asp-page="/Admin/Users/Index">Пользователи</a></li>
                        <li><a class="dropdown-item" asp-page="/Admin/Chats/Index">Чаты</a></li>
                        <li><a class="dropdown-item" asp-page="/Admin/Devices/Index">Устройства</a></li>
                    </ul>
                </li>
            }
        </ul>
        <div class="sidebar-footer">
            @if (SignInManager.IsSignedIn(User))
            {
                var appUser = await UserManager.GetUserAsync(User);
                var displayName = User.IsInRole("Administrator") ? "Админ" : appUser?.FirstName ?? appUser?.Email ?? "Пользователь";
                var avatarColor = appUser?.AvatarColor ?? "#6c757d";
                var initial = string.IsNullOrWhiteSpace(displayName) ? "?" : displayName.Substring(0, 1).ToUpper();

                <div class="avatar-circle" style="background-color: @avatarColor;">@initial</div>
                <div class="user-info">@displayName</div>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
                    <button type="submit" class="btn-logout">Выход</button>
                </form>
            }
            else
            {
                <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Войти</a>
                <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
            }
        </div>
    </aside>

    <!-- Основной контент -->
    <main class="main-content">
        <div class="content-wrap">
            @RenderBody()
        </div>
        <footer class="footer">
            <div class="container-fluid">
                &copy; 2026 – Беловская ГРЭС. Система сетевого мониторинга.
            </div>
        </footer>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>