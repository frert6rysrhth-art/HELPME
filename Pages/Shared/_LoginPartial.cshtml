@using Microsoft.AspNetCore.Identity
@using BelovskayaMonitoring.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var appUser = await UserManager.GetUserAsync(User);
        var displayName = User.IsInRole("Administrator") ? "Админ" : appUser?.FirstName ?? appUser?.Email ?? "Пользователь";
        var avatarColor = appUser?.AvatarColor ?? "#6c757d";
        var initial = string.IsNullOrWhiteSpace(displayName) ? "?" : displayName.Substring(0, 1).ToUpper();

        <li class="nav-item d-flex align-items-center">
            <span class="avatar-circle me-2" style="background-color: @avatarColor;">@initial</span>
            <span class="navbar-text me-2">@displayName</span>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Page("/Index")" method="post">
                <button type="submit" class="nav-link btn btn-link">Выйти</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Войти</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
        </li>
    }
</ul>