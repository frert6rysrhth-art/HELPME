@page
@model IndexModel
@{
    ViewData["Title"] = "Главная";
}

<div class="shield-panel">
    <div class="panel-title">Система сетевого мониторинга Беловской ГРЭС</div>
    <p style="color: var(--text-secondary); margin-bottom: 0.5rem;">
        Веб-приложение для контроля состояния телекоммуникационного оборудования, ведения журнала событий и оперативной коммуникации дежурной смены.
    </p>
    <p style="color: var(--text-secondary);">
        Используйте разделы <strong style="color: var(--accent-blue);">Чаты</strong> (коммуникация),
        <strong style="color: var(--accent-green);">Мониторинг</strong> (состояние оборудования) и
        <strong style="color: var(--accent-orange);">Аналитика</strong> (статистика сообщений).
    </p>
</div>

<!-- Фотография -->
<div class="shield-panel">
    <div class="panel-title">Фотография станции</div>
    <img src="~/images/belovskaya_gres.jpg" class="img-fluid" alt="Беловская ГРЭС" style="border: 1px solid var(--border-color);" />
</div>

<!-- Ключевые показатели -->
<div class="shield-panel">
    <div class="panel-title">Ключевые показатели</div>
    <div class="row g-3">
        <div class="col-md-3 d-flex">
            <div class="device-card online flex-fill d-flex flex-column justify-content-center text-center">
                <div class="mono-font" style="font-size: 2rem; color: var(--accent-green);">1260</div>
                <div class="text-secondary">Установленная электрическая мощность, МВт</div>
            </div>
        </div>
        <div class="col-md-3 d-flex">
            <div class="device-card online flex-fill d-flex flex-column justify-content-center text-center">
                <div class="mono-font" style="font-size: 2rem; color: var(--accent-green);">229</div>
                <div class="text-secondary">Теплофикационная мощность, Гкал/ч</div>
            </div>
        </div>
        <div class="col-md-3 d-flex">
            <div class="device-card online flex-fill d-flex flex-column justify-content-center text-center">
                <div class="mono-font" style="font-size: 2rem; color: var(--accent-green);">6</div>
                <div class="text-secondary">Энергоблоков в эксплуатации</div>
            </div>
        </div>
        <div class="col-md-3 d-flex">
            <div class="device-card online flex-fill d-flex flex-column justify-content-center text-center">
                <div class="mono-font" style="font-size: 2rem; color: var(--accent-green);">~33%</div>
                <div class="text-secondary">Доля в выработке Кузбасса</div>
            </div>
        </div>
    </div>
</div>

<!-- Общая информация + Технические характеристики -->
<div class="row g-3">
    <div class="col-lg-7">
        <div class="shield-panel h-100">
            <div class="panel-title">Общая информация</div>
            <table class="table" style="margin-bottom: 0;">
                <tr><td style="color: var(--text-secondary); width: 200px;">Полное название</td><td>Беловская ГРЭС (Государственная районная электростанция)</td></tr>
                <tr><td style="color: var(--text-secondary);">Расположение</td><td>посёлок Инской, г. Белово, Кемеровская область, левый берег реки Иня, 12 км восточнее города</td></tr>
                <tr><td style="color: var(--text-secondary);">Ввод в эксплуатацию</td><td>29 июня 1964 года (первый энергоблок)</td></tr>
                <tr><td style="color: var(--text-secondary);">Собственник</td><td>АО «Кузбассэнерго», Группа «Сибирская генерирующая компания» (СГК)</td></tr>
                <tr><td style="color: var(--text-secondary);">Основное топливо</td><td>Каменный уголь Кузнецкого бассейна</td></tr>
                <tr><td style="color: var(--text-secondary);">Награды</td><td>Орден «Знак Почёта» (1974)</td></tr>
            </table>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="shield-panel h-100">
            <div class="panel-title">Технические характеристики</div>
            <table class="table" style="margin-bottom: 0;">
                <tr><td style="color: var(--text-secondary);">Электрическая мощность</td><td>1260 МВт</td></tr>
                <tr><td style="color: var(--text-secondary);">Тепловая мощность</td><td>229 Гкал/ч</td></tr>
                <tr><td style="color: var(--text-secondary);">Количество энергоблоков</td><td>6 (4×200 + 2×230 МВт)</td></tr>
                <tr><td style="color: var(--text-secondary);">Котлы</td><td>6 × ПК-40-1 (640 т/ч)</td></tr>
                <tr><td style="color: var(--text-secondary);">Турбогенераторы</td><td>6 × ТВВ-200-2АУЗ</td></tr>
                <tr><td style="color: var(--text-secondary);">Подстанция</td><td>500 кВ, ОРУ 110 и 220 кВ</td></tr>
            </table>
        </div>
    </div>
</div>

<!-- История строительства -->
<div class="shield-panel mt-3">
    <div class="panel-title">История строительства</div>
    <table class="table" style="margin-bottom: 0;">
        <tr><td class="mono-font" style="color: var(--accent-orange); width: 120px;">1955</td><td>Беловская ГРЭС объявлена Всесоюзной ударной комсомольской стройкой. Начало строительства.</td></tr>
        <tr><td class="mono-font" style="color: var(--accent-orange);">1962</td><td>Перекрыто русло реки Иня, началось заполнение Беловского водохранилища.</td></tr>
        <tr><td class="mono-font" style="color: var(--accent-orange);">1963</td><td>Готов фундамент главного корпуса, начат монтаж оборудования.</td></tr>
        <tr><td class="mono-font" style="color: var(--accent-orange);">1964</td><td>Первый энергоблок мощностью 200 МВт поставлен под нагрузку.</td></tr>
        <tr><td class="mono-font" style="color: var(--accent-orange);">1964</td><td>Беловская ГРЭС дала первый миллион киловатт-часов электроэнергии.</td></tr>
        <tr><td class="mono-font" style="color: var(--accent-orange);">1968</td><td>С вводом шестого энергоблока станция достигла проектной мощности 1200 МВт.</td></tr>
        <tr><td class="mono-font" style="color: var(--accent-orange);">1974</td><td>Награждение Орденом «Знак Почёта».</td></tr>
        <tr><td class="mono-font" style="color: var(--accent-orange);">2015</td><td>Модернизация, увеличение мощности до 1260 МВт.</td></tr>
    </table>
</div>

<!-- Значение для региона -->
<div class="shield-panel mt-3">
    <div class="panel-title">Значение для региона</div>
    <p>Беловская ГРЭС — вторая по мощности электростанция Кузбасса, обеспечивающая около трети всей вырабатываемой в Кемеровской области электроэнергии.</p>
    <p>Через высоковольтные линии электропередачи энергия поступает в Кемерово, Новокузнецк, Белово, Ленинск-Кузнецкий и другие города, а также на пять крупных угледобывающих предприятий.</p>
    <p>Беловское водохранилище, созданное для нужд станции, сегодня известно как «Беловское море» — популярное место отдыха и рыбалки для жителей всего Кузбасса.</p>
</div>