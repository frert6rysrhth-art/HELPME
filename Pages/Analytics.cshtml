@page
@model BelovskayaMonitoring.Pages.AnalyticsModel
@{
    ViewData["Title"] = "Аналитика чатов";
}

<div class="shield-panel">
    <div class="panel-title">Сводка</div>
    <div class="row" id="summaryCards"></div>
</div>

<div class="shield-panel">
    <div class="panel-title">Нагрузка по часам</div>
    <canvas id="hourlyLoadChart" height="100"></canvas>
</div>

<div class="row mt-3">
    <div class="col-md-6">
        <div class="shield-panel">
            <div class="panel-title">Топ активных пользователей</div>
            <div class="chart-container">
                <canvas id="topUsersChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="shield-panel">
            <div class="panel-title">Типы сообщений</div>
            <div class="chart-container">
                <canvas id="messageTypeChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="shield-panel mt-3">
    <div class="panel-title">Последние события</div>
    <table class="table table-sm table-dark-striped">
        <thead><tr><th>Время</th><th>Тип</th><th>Описание</th></tr></thead>
        <tbody id="activityFeed"></tbody>
    </table>
</div>

@section Scripts {
    <script src="~/lib/chart.js/chart.min.js"></script>
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script>
        let hourlyChart = null;
        let topUsersChart = null;
        let messageTypeChart = null;

        async function loadData() {
            try {
                const summaryRes = await fetch('/api/analytics/summary');
                const summary = await summaryRes.json();
                renderSummaryCards(summary);

                const loadRes = await fetch('/api/analytics/hourlyload');
                const loadData = await loadRes.json();
                renderHourlyLoad(loadData);

                const topRes = await fetch('/api/analytics/topusers');
                const topData = await topRes.json();
                renderTopUsers(topData);

                const ratioRes = await fetch('/api/analytics/messagetyperatio');
                const ratio = await ratioRes.json();
                renderMessageType(ratio);

                const activityRes = await fetch('/api/analytics/recentactivity');
                const activity = await activityRes.json();
                renderActivityFeed(activity);
            } catch (e) {
                console.error(e);
            }
        }

        function renderSummaryCards(s) {
            document.getElementById('summaryCards').innerHTML = `
                <div class="col-md-3 mb-3 d-flex">
                    <div class="device-card online text-center flex-fill">
                        <div class="mono-font" style="font-size: 2rem; color: var(--accent-green);">${s.totalUsers}</div>
                        <div class="text-secondary">Пользователей</div>
                        <small>Активных: ${s.activeUsers}</small>
                    </div>
                </div>
                <div class="col-md-3 mb-3 d-flex">
                    <div class="device-card online text-center flex-fill">
                        <div class="mono-font" style="font-size: 2rem; color: var(--accent-green);">${s.totalChats}</div>
                        <div class="text-secondary">Чатов</div>
                        <small>Системных: ${s.systemChats}</small>
                    </div>
                </div>
                <div class="col-md-3 mb-3 d-flex">
                    <div class="device-card online text-center flex-fill">
                        <div class="mono-font" style="font-size: 2rem; color: var(--accent-blue);">${s.messagesToday}</div>
                        <div class="text-secondary">Сообщений сегодня</div>
                    </div>
                </div>
                <div class="col-md-3 mb-3 d-flex">
                    <div class="device-card ${s.alertsToday > 0 ? 'offline' : 'online'} text-center flex-fill">
                        <div class="mono-font" style="font-size: 2rem; color: ${s.alertsToday > 0 ? 'var(--accent-red)' : 'var(--accent-green)'};">${s.alertsToday}</div>
                        <div class="text-secondary">Аварий сегодня</div>
                    </div>
                </div>`;
        }

        function renderHourlyLoad(data) {
            if (hourlyChart) hourlyChart.destroy();
            const labels = data.map(d => d.hour.substring(11,16));
            hourlyChart = new Chart(document.getElementById('hourlyLoadChart'), {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Всего', data: data.map(d => d.total), borderColor: '#3b82f6', backgroundColor: 'transparent' },
                        { label: 'Системные', data: data.map(d => d.system), borderColor: '#ef4444', backgroundColor: 'transparent' },
                        { label: 'Пользовательские', data: data.map(d => d.user), borderColor: '#22c55e', backgroundColor: 'transparent' }
                    ]
                },
                options: {
                    scales: {
                        x: { ticks: { color: '#a4abb7' }, grid: { color: '#4b5563' } },
                        y: { ticks: { color: '#a4abb7' }, grid: { color: '#4b5563' } }
                    },
                    plugins: { legend: { labels: { color: '#e0e4e9' } } }
                }
            });
        }

        function renderTopUsers(data) {
            if (topUsersChart) topUsersChart.destroy();
            topUsersChart = new Chart(document.getElementById('topUsersChart'), {
                type: 'bar',
                data: {
                    labels: data.map(d => d.name),
                    datasets: [{ label: 'Сообщений', data: data.map(d => d.count), backgroundColor: '#f97316' }]
                },
                options: {
                    indexAxis: 'y',
                    scales: {
                        x: { ticks: { color: '#a4abb7' }, grid: { color: '#4b5563' } },
                        y: { ticks: { color: '#a4abb7' }, grid: { color: '#4b5563' } }
                    },
                    plugins: { legend: { labels: { color: '#e0e4e9' } } }
                }
            });
        }

        function renderMessageType(ratio) {
            if (messageTypeChart) messageTypeChart.destroy();
            messageTypeChart = new Chart(document.getElementById('messageTypeChart'), {
                type: 'doughnut',
                data: {
                    labels: ['Обычные', 'Системные'],
                    datasets: [{ data: [ratio.user, ratio.system], backgroundColor: ['#22c55e', '#ef4444'] }]
                },
                options: {
                    plugins: { legend: { labels: { color: '#e0e4e9' } } }
                }
            });
        }

        function renderActivityFeed(activities) {
            document.getElementById('activityFeed').innerHTML = activities.map(a =>
                `<tr><td class="mono-font">${a.time}</td><td>${a.type}</td><td>${a.description}</td></tr>`
            ).join('');
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        connection.on("RefreshAnalytics", () => { loadData(); });
        connection.start().catch(err => console.error(err));
        loadData();
    </script>
}