@page "{chatId:int}"
@model BelovskayaMonitoring.Pages.Chats.RoomModel
@{
    ViewData["Title"] = Model.Chat?.Name ?? "Чат";
}

<div class="shield-panel">
    <div class="d-flex justify-content-between align-items-center panel-title" style="border-bottom: none; margin-bottom: 1rem;">
        <span>@Model.Chat?.Name</span>
        <a asp-page="/Chats/Index" class="btn btn-outline-secondary btn-sm">← Назад к списку</a>
    </div>

    <!-- Панель действий -->
    <div class="d-flex justify-content-end mb-3 gap-2">
        <a href="/api/export/chat/@Model.Chat?.Id" class="btn btn-outline-secondary btn-sm" title="Скачать TXT">📄 Экспорт</a>
        @if (Model.IsAdmin)
        {
            <form method="post" asp-page-handler="ClearHistory" asp-route-chatId="@Model.Chat?.Id" onsubmit="return confirm('Удалить все сообщения в этом чате?');" class="m-0">
                <button type="submit" class="btn btn-outline-danger btn-sm" title="Очистить историю">🗑 Очистить</button>
            </form>
        }
        <button type="button" class="btn btn-outline-info btn-sm" title="Информация о чате" onclick="openChatInfo(@Model.Chat?.Id, '@Model.Chat?.Name', @(Model.Chat?.IsSystem ?? false ? "true" : "false"))">ℹ️ Инфо</button>

        @{
            var isSystemChat = Model.Chat?.IsSystem ?? false;
        }
        @if (isSystemChat)
        {
            <button type="button" class="btn btn-outline-danger btn-sm" onclick="alert('Вы не можете покинуть этот чат.')">Покинуть</button>
        }
        else
        {
            <form method="post" asp-page-handler="Leave" asp-route-chatId="@Model.Chat?.Id" onsubmit="return confirm('Вы уверены, что хотите покинуть чат?');" class="m-0">
                <button type="submit" class="btn btn-outline-danger btn-sm">Покинуть</button>
            </form>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-warning" style="background-color: var(--bg-panel-alt); border-color: var(--accent-yellow); color: var(--accent-yellow);">@Model.StatusMessage</div>
    }

    <!-- Сообщения -->
    <div id="messagesContainer" style="max-height: 500px; overflow-y: auto; border: 1px solid var(--border-color); padding: 10px; background-color: var(--bg-panel-alt); margin-bottom: 1rem;">
        @foreach (var msg in Model.Messages)
        {
            <div class="mb-2 d-flex align-items-start gap-2">
                @if (msg.Sender == null && msg.SenderId == null)
                {
                    <div style="width: 32px; height: 32px; border-radius: 50%; background: #6c757d; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 16px;">⚙️</div>
                    <div>
                        <strong>Система</strong> <small class="mono-font" style="color: var(--text-secondary);">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</small>
                        <p class="mb-0">@msg.Text</p>
                    </div>
                }
                else
                {
                    var userColor = msg.Sender?.AvatarColor ?? "#3366CC";
                    var userInitial = (msg.Sender?.FirstName?.Substring(0, 1) ?? "?").ToUpper();
                    <div style="width: 32px; height: 32px; border-radius: 50%; background: @userColor; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 16px; cursor: pointer;"
                         onclick="showUserCard('@msg.SenderId', '@userInitial', '@userColor')">
                        @userInitial
                    </div>
                    <div>
                        <strong style="cursor: pointer;" onclick="showUserCard('@msg.SenderId', '@userInitial', '@userColor')">@(msg.Sender?.FirstName + " " + msg.Sender?.LastName)</strong>
                        <small style="color: var(--text-secondary);">(@msg.Sender?.Email)</small>
                        <small class="mono-font" style="color: var(--text-secondary);">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</small>
                        <p class="mb-0">@msg.Text</p>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Ввод сообщения -->
    <div class="input-group">
        <input type="text" id="messageInput" class="form-control" placeholder="Введите сообщение..." style="background-color: var(--bg-panel); color: var(--text-primary); border-color: var(--border-color);">
        <button id="sendButton" class="btn btn-primary">Отправить</button>
    </div>
</div>

<!-- Модальные окна (информация о чате и карточка пользователя) -->
<div class="modal fade" id="chatInfoModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="background-color: var(--bg-panel); color: var(--text-primary);">
            <div class="modal-header" style="border-bottom: 1px solid var(--border-color);">
                <h5 class="modal-title">Информация о чате</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong>Название:</strong> <span id="ciName"></span></p>
                <p><strong>Тип:</strong> <span id="ciType"></span></p>
                <p><strong>Участники:</strong></p>
                <ul id="ciParticipants" class="list-unstyled"></ul>
            </div>
            <div class="modal-footer" style="border-top: 1px solid var(--border-color);">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="userCardModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content" style="background-color: var(--bg-panel); color: var(--text-primary);">
            <div class="modal-body text-center">
                <div id="ucAvatar" style="width: 60px; height: 60px; border-radius: 50%; margin: 0 auto 10px; display: flex; align-items: center; justify-content: center; color: white; font-size: 28px; font-weight: bold;"></div>
                <h5 id="ucName"></h5>
                <p class="text-muted mb-1" id="ucPosition"></p>
                <p class="text-muted mb-1" id="ucDepartment"></p>
                <p class="mb-1" id="ucPhone"></p>
                <p class="text-muted" id="ucEmail"></p>
                <p id="ucRoles"></p>
            </div>
            <div class="modal-footer" style="border-top: 1px solid var(--border-color);">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script>
        const chatId = @Model.Chat?.Id;
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        connection.on("ReceiveMessage", (data) => {
            const container = document.getElementById("messagesContainer");
            const div = document.createElement("div");
            div.className = "mb-2 d-flex align-items-start gap-2";
            let avatarHtml = '';
            let senderHtml = '';
            if (data.senderName === 'Система') {
                avatarHtml = `<div style="width: 32px; height: 32px; border-radius: 50%; background: #6c757d; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 16px;">⚙️</div>`;
                senderHtml = `<strong>Система</strong>`;
            } else {
                const userColor = data.senderColor || '#3366CC';
                const initial = data.senderName ? data.senderName.charAt(0).toUpperCase() : '?';
                avatarHtml = `<div style="width: 32px; height: 32px; border-radius: 50%; background: ${userColor}; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 16px; cursor: pointer;" onclick="showUserCard('${data.senderId}', '${initial}', '${userColor}')">${initial}</div>`;
                senderHtml = `<strong style="cursor: pointer;" onclick="showUserCard('${data.senderId}', '${initial}', '${userColor}')">${data.senderName}</strong> <small style="color: var(--text-secondary);">(${data.senderEmail})</small>`;
            }
            div.innerHTML = `${avatarHtml}<div>${senderHtml} <small class="mono-font" style="color: var(--text-secondary);">${data.timestamp}</small><p class="mb-0">${data.text}</p></div>`;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        });

        connection.on("Error", (error) => { alert(error); });
        connection.start().catch(err => console.error(err));

        document.getElementById("sendButton").addEventListener("click", () => {
            const input = document.getElementById("messageInput");
            const text = input.value.trim();
            if (text) {
                connection.invoke("SendMessage", chatId, text).catch(err => console.error(err));
                input.value = "";
            }
        });

        document.getElementById("messageInput").addEventListener("keypress", (e) => {
            if (e.key === "Enter") { document.getElementById("sendButton").click(); }
        });

        // Модальные окна (скопированы из предыдущего кода)
        async function openChatInfo(chatId, chatName, isSystem) {
            document.getElementById('ciName').textContent = chatName;
            document.getElementById('ciType').textContent = isSystem ? 'Системный' : 'Обычный';
            const participantsList = document.getElementById('ciParticipants');
            participantsList.innerHTML = '';
            try {
                const response = await fetch(`/api/users/chat/${chatId}`);
                if (response.ok) {
                    const users = await response.json();
                    users.forEach(u => {
                        const li = document.createElement('li');
                        li.innerHTML = `<span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background-color: ${u.avatarColor}; margin-right: 5px;"></span> ${u.firstName} ${u.lastName} (${u.email})`;
                        participantsList.appendChild(li);
                    });
                }
            } catch (e) { console.error(e); }
            new bootstrap.Modal(document.getElementById('chatInfoModal')).show();
        }

        async function showUserCard(userId, initial, color) {
            try {
                const response = await fetch(`/api/users/${userId}`);
                if (response.ok) {
                    const user = await response.json();
                    document.getElementById('ucAvatar').style.backgroundColor = user.avatarColor;
                    document.getElementById('ucAvatar').textContent = user.firstName ? user.firstName.charAt(0).toUpperCase() : '?';
                    document.getElementById('ucName').textContent = `${user.firstName} ${user.lastName}`;
                    document.getElementById('ucPosition').textContent = user.position || '';
                    document.getElementById('ucDepartment').textContent = user.department || '';
                    document.getElementById('ucPhone').textContent = user.phoneNumber || '';
                    document.getElementById('ucEmail').textContent = user.email;
                    document.getElementById('ucRoles').textContent = user.roles ? `Роли: ${user.roles.join(', ')}` : '';
                } else {
                    document.getElementById('ucAvatar').style.backgroundColor = color;
                    document.getElementById('ucAvatar').textContent = initial;
                    document.getElementById('ucName').textContent = 'Пользователь';
                    document.getElementById('ucPosition').textContent = '';
                    document.getElementById('ucDepartment').textContent = '';
                    document.getElementById('ucPhone').textContent = '';
                    document.getElementById('ucEmail').textContent = '';
                    document.getElementById('ucRoles').textContent = '';
                }
            } catch (e) { console.error(e); }
            new bootstrap.Modal(document.getElementById('userCardModal')).show();
        }
    </script>
}